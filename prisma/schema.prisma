generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  CASHIER
}

enum Locale {
  id
  en
}

enum PaymentMethod {
  CASH
  DIGITAL
}

enum TransactionStatus {
  COMPLETED
  VOIDED
}

enum TransactionLogAction {
  EDIT
  SOFT_DELETE
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
  categories Category[]
  users    User[]

  @@index([name])
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cashierUsers User[]        @relation("CashierBranch")
  products     Product[]
  transactions Transaction[]

  @@index([name])
  @@index([companyId])
  @@unique([companyId, name])
}

/// NOTE: This is compatible with NextAuth's Prisma Adapter when used with the
/// Account/Session/VerificationToken models below.
/// Multi-tenant rule: every user is assigned to exactly one branch.
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  image     String?
  passwordHash String?
  isActive  Boolean  @default(true)
  role      Role     @default(CASHIER)
  locale    Locale   @default(id)
  companyId String
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch?     @relation("CashierBranch", fields: [branchId], references: [id], onDelete: Restrict)
  accounts     Account[]
  sessions     Session[]
  transactions Transaction[]
  transactionLogs TransactionLog[] @relation("TransactionLogActor")

  @@index([companyId])
  @@index([branchId])
  @@index([role])
}

// Enforce "one cashier account for one branch" by convention in code:
// - role=CASHIER => branchId required
// - role in (OWNER, ADMIN) => branchId optional

model Category {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
}

/// "Menu item" with inventory cost tracking (COGS).
/// Price and costPrice are stored as Decimals for currency safety.
model Product {
  id         String   @id @default(cuid())
  branchId   String
  categoryId String

  name      String
  sku       String?
  price     Decimal  @db.Decimal(12, 2)
  costPrice Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  items    TransactionItem[]

  @@index([branchId])
  @@index([categoryId])
  @@unique([branchId, sku])
}

/// One checkout ("receipt").
/// Totals are stored to make reporting fast and consistent even if product prices change later.
model Transaction {
  id            String            @id @default(cuid())
  branchId      String
  cashierUserId String
  status        TransactionStatus @default(COMPLETED)
  paymentMethod PaymentMethod

  subtotal       Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)

  receivedAmount Decimal? @db.Decimal(12, 2)
  changeAmount   Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)
  cashier User  @relation(fields: [cashierUserId], references: [id], onDelete: Restrict)
  items   TransactionItem[]
  logs    TransactionLog[]

  @@index([branchId, createdAt])
  @@index([cashierUserId, createdAt])
  @@index([status, createdAt])
}

model TransactionLog {
  id            String             @id @default(cuid())
  transactionId String
  actorUserId   String
  action        TransactionLogAction
  before        Json?
  after         Json?
  createdAt     DateTime           @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  actor       User        @relation("TransactionLogActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([transactionId, createdAt])
  @@index([actorUserId, createdAt])
}

/// Line items snapshot unitPrice/unitCost for accurate historical profit:
/// Profit per item = unitPrice - unitCost
model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  productId     String?

  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  unitCost    Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([productId])
}

// -----------------------------
// NextAuth.js Prisma Adapter models
// -----------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
