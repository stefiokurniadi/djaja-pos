# Use your Neon (or other Postgres) connection string. Copy to `.env`.
# Prisma CLI reads DATABASE_URL from `prisma.config.ts` using the project root `.env`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
# Local: http://localhost:3000 | Vercel prod: https://your-app.vercel.app (or custom domain) — not localhost
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_me_with_a_long_random_string"

